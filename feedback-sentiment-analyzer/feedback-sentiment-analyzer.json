    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.content.parts[0].text;\nconst cleaned = raw.replace(/```json|```/g, \"\").trim();\nconst parsed = JSON.parse(cleaned);\n\nreturn {\n  json: {\n    ...($input.item.json),\n    sentiment: parsed.sentiment,\n    urgency: parsed.urgency\n  }\n};"
      },
