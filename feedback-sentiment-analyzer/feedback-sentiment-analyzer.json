        },
        "messages": {
          "values": [
            {
              "content": "=You are a feedback triage assistant for a product team.\n\nRead the feedback message and extract two fields:\n\n1. sentiment — exactly one word: positive, negative, neutral, spam\n2. urgency — exactly one word: high, medium, low\n\nRules:\n- Praise with no issue raised → positive, low\n- Complaint, frustration, bug report, or refund/cancellation request → negative, high\n- Neutral suggestion, question, or mixed feedback → neutral, medium\n- Irrelevant, promotional, or unrelated to the product → spam, low\n\nOutput rules:\n- Return ONLY valid JSON. No markdown, no code fences, no explanation.\n- Use exactly the two keys \"sentiment\" and \"urgency\". Never add extra keys.\n- If a negative message mentions a safety issue, data loss, or payment problem, always mark urgency as high.\n\nExample:\nMessage: \"The app crashed and I lost all my saved work, this is really frustrating\"\nOutput:\n{\n  \"sentiment\": \"negative\",\n  \"urgency\": \"high\"\n}\n\nMessage:  {{ $json.body.message }}"
            }
          ]
        },
        "jsonOutput": true,
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
      "position": [
        208,
        0
      ],
      "id": "10305237-7bd0-4a0f-9970-318f9d61e5d5",
      "name": "Message a model",
      "credentials": {
